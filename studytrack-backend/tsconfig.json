{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "outDir": "./dist",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "sourceMap": true,
    "rootDir": ".",
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/**/*", "server.ts"],
  "exclude": ["node_modules", "dist", "__tests__"]
}
